# Resend API key — get yours at https://resend.com
# Without this key, contact form submissions are logged to console (dev mode).
RESEND_API_KEY=re_xxxxxxxxxx

# Canonical production URL — used for metadataBase, sitemap.xml, and robots.txt.
# Must be set in Vercel project env vars before going live.
NEXT_PUBLIC_SITE_URL=https://kemmatech.com
